# BEGIN dk-lp-legacy-redirects
# WP旧LP slug → 静的LP（denki-lp-cvr）。deploy.yml が自動適用。
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteRule ^denkikouji-kyujin-2/?(.*)$ /denki-lp-cvr/denkikouji/$1 [R=301,L,QSA,NC]
RewriteRule ^sekokan/?(.*)$ /denki-lp-cvr/sekoukanri/$1 [R=301,L,QSA,NC]
</IfModule>
# END dk-lp-legacy-redirects
